# =============================================================================
# GenerativeMiner Environment Configuration
# =============================================================================
# Copy this file to .env.miner and configure your settings
# cp .env.gen_miner.template .env.gen_miner

# =============================================================================
# GENERATION SERVICE SELECTION
# =============================================================================
# Choose which service to use for each modality:
#   openai      - DALL-E 3 / Sora video (requires OPENAI_API_KEY). OpenAI deprecates
#                 the Videos API and Sora 2 models; shutdown 2026-09-24 — prefer Runway
#                 for long-lived video (VIDEO_SERVICE=runway).
#   openrouter  - Image (any image-output model, default: gemini-3-pro-image-preview)
#                 + Video (Veo 3.1 / Seedance) via OpenRouter (requires
#                 OPEN_ROUTER_API_KEY). Video models gated to C2PA-capable only:
#                 (google/veo-3.1*, bytedance/seedance-*). Kling, Wan, Hailuo,
#                 and Sora are excluded — they don't produce verifiable C2PA.
#   stabilityai - Stability AI (requires STABILITY_API_KEY)
#   runway      - Runway text-to-video (requires RUNWAYML_API_KEY)
#   none        - Disable this modality (requests will be rejected)
#
# All services produce C2PA-signed content required by validators.
#
# If IMAGE_SERVICE / VIDEO_SERVICE are not set, every backend with a valid key is
# loaded; the first match in openai → openrouter → stabilityai → runway wins per
# modality. For video, OpenAI (Sora) wins over Runway if both keys exist — set
# VIDEO_SERVICE=runway explicitly to use Runway for /gen_video. Set
# VIDEO_SERVICE=openrouter to use Veo/Seedance via OpenRouter.
IMAGE_SERVICE=openrouter
VIDEO_SERVICE=openrouter


# =============================================================================
# API KEYS (configure the services you want to use)
# =============================================================================

# OpenAI DALL-E
OPENAI_API_KEY=

# OpenRouter (multi-model access - recommended)
OPEN_ROUTER_API_KEY=

# Stability AI
STABILITY_API_KEY=

# Runway (text-to-video when VIDEO_SERVICE=runway). RUNWAYML_API_SECRET is an alias (SDK default).
RUNWAYML_API_KEY=

# Hugging Face (for model downloads)
HUGGINGFACE_HUB_TOKEN=

# Google Cloud (if using Vertex AI)
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1  
# GOOGLE_APPLICATION_CREDENTIALS=

# =============================================================================
# BITTENSOR NETWORK
# =============================================================================

# Network Configuration
BT_NETUID=379
BT_CHAIN_ENDPOINT=wss://test.finney.opentensor.ai:443

# Wallet
BT_WALLET_NAME=miner1
BT_WALLET_HOTKEY=default

# Axon (your miner's endpoint)
BT_AXON_PORT=8093
BT_AXON_IP=0.0.0.0
# BT_AXON_EXTERNAL_IP=your.public.ip

# =============================================================================
# MINER SETTINGS
# =============================================================================

# Performance
MINER_DEVICE=auto
MINER_MAX_CONCURRENT_TASKS=5
MINER_TASK_TIMEOUT=300

# Storage
HF_HOME=/workspace/.cache/huggingface

# Set to true to save generated images/videos under MINER_OUTPUT_DIR/image/ and .../video/
MINER_SAVE_LOCALLY=true
MINER_OUTPUT_DIR=./miner_generated_content

# Optional: durable task snapshots for restart recovery (default: <MINER_OUTPUT_DIR>/.gen_miner_state)
# MINER_STATE_DIR=


# =============================================================================
# LOGGING
# =============================================================================

BT_LOGGING_LEVEL=INFO

# =============================================================================
# USAGE EXAMPLES
# =============================================================================

# Start miner:     gascli generator start
# Check status:    gascli generator status  
# View logs:       gascli generator logs -f
# Direct PM2:      pm2 start miner.config.js

# Get API keys:
# - OpenAI: https://platform.openai.com/api-keys
# - OpenRouter: https://openrouter.ai/keys
# - Runway: https://app.runwayml.com/ (API keys / dev portal)
# - Hugging Face: https://huggingface.co/settings/tokens